# Source Qdrant (local Docker, server mode)
QDRANT_SOURCE_URL=http://localhost:6333
QDRANT_SOURCE_API_KEY=

# Qdrant Cloud (destination)
QDRANT_CLOUD_URL=https://your-cluster-id.your-region.aws.cloud.qdrant.io
QDRANT_CLOUD_API_KEY=your-cloud-api-key

# Shared
QDRANT_COLLECTION_NAME=egyptian_law
QDRANT_TIMEOUT=60

# Embedding service (BGE-M3 embed + rerank, deployed separately on Hetzner)
EMBEDDING_SERVICE_URL=https://your-vps-ip-or-domain
EMBEDDING_SERVICE_TOKEN=your-embedding-service-bearer-token

GOOGLE_API_KEY=
LLM_MODEL=
# Cheaper model for conversation-summary compaction; defaults to
# gemini-3.5-flash-lite in config.py if left blank.
SUMMARY_LLM_MODEL=

# Postgres (users, conversations, messages). Dev default matches
# docker-compose.yml. In Railway, set this to the managed Postgres plugin's
# connection string (its ${{Postgres.DATABASE_URL}} reference var) -- a
# `postgres://` or `postgresql://` scheme is normalized to
# `postgresql+asyncpg://` automatically in config.py, no edits needed.
DATABASE_URL=postgresql+asyncpg://legal_assistant:legal_assistant_dev@localhost:5432/legal_assistant

# API (FastAPI): session-identity token signing + CORS. Generate a real
# secret for anything beyond local dev, e.g. `python -c "import secrets; print(secrets.token_hex(32))"`.
SECRET_KEY=dev-only-insecure-secret-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=10080
# Restrict to the real deployed origin(s) in production -- no wildcard.
# e.g. CORS_ALLOW_ORIGINS=["https://your-app.up.railway.app"]
CORS_ALLOW_ORIGINS=["http://localhost:3000"]

# Langfuse Cloud (observability). Optional -- leave both keys blank to run
# with tracing disabled (chat/feedback work identically either way).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com